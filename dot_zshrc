export PATH="$HOME/.devcontainers/bin:$PATH"
export XDG_CONFIG_HOME="$HOME/.config"
export HOMEBREW_NO_ENV_HINTS=1
export EDITOR="code"
export PATH="$HOME/.local/bin:$PATH" # used by Pi

# Load .zsh completions
fpath=(~/.zsh/completions $fpath)
autoload -Uz compinit
compinit

# Load shell tools
eval "$(starship init zsh)"
eval "$(intelli-shell init zsh)"

# Set up fzf key bindings and fuzzy completion
source <(fzf --zsh)

# Source brew zsh files 
source $(brew --prefix)/share/zsh-autosuggestions/zsh-autosuggestions.zsh
source $(brew --prefix)/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh

# Disable underline highlight
(( ${+ZSH_HIGHLIGHT_STYLES} )) || typeset -A ZSH_HIGHLIGHT_STYLES
ZSH_HIGHLIGHT_STYLES[path]=none
ZSH_HIGHLIGHT_STYLES[path_prefix]=none

# Move cursor on shift arrow key press
bindkey "\e[1;2D" backward-char
bindkey "\e[1;2C" forward-char

# Load .env.ssh (when available)
test -f $HOME/.ssh/.env.ssh && source $HOME/.ssh/.env.ssh

# Load .zsh files (when available)
test -f $HOME/.zsh/aliases && source $HOME/.zsh/aliases
test -f $HOME/.zsh/functions && source $HOME/.zsh/functions
test -f $HOME/.zshrc.local && source $HOME/.zshrc.local

if command -v wt >/dev/null 2>&1; then eval "$(command wt config shell init zsh)"; fi
